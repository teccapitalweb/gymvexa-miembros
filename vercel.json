{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/__/auth/:path*",     "destination": "https://gymteck-1708f.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/:path*", "destination": "https://gymteck-1708f.firebaseapp.com/__/firebase/:path*" },
    { "source": "/(.*)",               "destination": "/index.html" }
  ]
}
